# Ignore intermediate build output, but DO track the final PDFs and EPUBs.
editions/*/output/**
!editions/*/output/
!editions/*/output/*/
!editions/*/output/**/*.pdf
!editions/*/output/**/*.epub
__pycache__/
*.pyc
*.psd
*.bak
*.prepatch-bak
*.pre-merge-bak.md
.DS_Store
.unused-images-quarantine/
engine/.pdf-baseline.json
.unused-quarantine/

# Private per-chapter commentary written for Cole (audience: Cole Kraft).
# Not part of the book; never built or published. Keep local, out of the repo.
editions/*/content/commentary/
